---
import BaseLayout from '../layouts/BaseLayout.astro';

const courses = [
  {
    title: "Advanced RAG Mastery",
    description: "Your RAG works in the notebook. It fails in production. This 4-week intensive fixes that — hybrid search, cross-encoder re-ranking, LLM-as-judge evaluation, and AWS deployment with monitoring. 8 seats left. Starting March 27.",
    tags: ["RAG", "LangChain", "Pinecone", "RAGAS", "AWS Lambda", "DeepEval"],
    status: "open",
    statusLabel: "Starting Mar 27",
    price: "₹24,999",
    seats: "Limited seats",
    link: "/courses/advanced-rag-mastery",
  },

  {
    title: "Production AI Engineering",
    description: "",
    tags: [],
    status: "closed",
    statusLabel: "Jan 2026",
    price: null,
    seats: null,
    link: null,
  },
  
  {
    title: "GenAI from First Principles",
    description: "",
    tags: [],
    status: "closed",
    statusLabel: "Oct 2025",
    price: null,
    seats: null,
    link: null,
  },
];
---

<BaseLayout>
  <div class="container">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-layout">
        <div class="hero-content">
          <span class="hero-tag">AI Engineer &amp; Educator</span>
          <h1>Hey, I'm Aishit</h1>
          <p class="hero-subtitle">Production AI Engineering, From First Principles.</p>
        </div>
        <div class="hero-photo-wrap">
          <img src="/aishit.jpg" alt="Aishit Dharwal" class="hero-photo" />
        </div>
      </div>

      <div class="hero-bio">
        <p>
          Most engineers can build an AI demo. Few can ship one that actually works in production —
          handles real traffic, fails gracefully, and doesn't hallucinate on your users.
          That gap is exactly what I work on.
        </p>
        <p>
          I'm Head of AI at <a href="https://skooc.com" target="_blank">Skooc</a>, where I've built production AI systems
          from scratch — RAG pipelines, evaluation frameworks, LLM fine-tuning, and AWS deployments that
          serve real users. I founded <a href="#courses">AI Classroom</a> to teach the same production-grade thinking
          to engineers who are tired of their AI projects dying in staging.
        </p>
        <p>
          Civil Engineering from <strong>IIT Bombay</strong>. Self-taught everything in AI.
          I've broken enough things in production that I now teach from real failure modes, not textbooks.
          I share the unfiltered version on <a href="https://instagram.com/aishit.builds" target="_blank">Instagram</a> and
          <a href="https://linkedin.com/in/aishit-dharwal" target="_blank">LinkedIn</a>.
        </p>
      </div>

      <div class="social-links">
        <!-- LinkedIn -->
        <a class="social-btn" href="https://linkedin.com/in/aishit-dharwal" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>

        <!-- Instagram -->
        <a class="social-btn" href="https://instagram.com/aishit.builds" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          aishit.builds
        </a>

{/*
        <!-- GitHub -->
        <a class="social-btn" href="https://github.com/aishitdharwal" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          GitHub
        </a>

        <!-- WhatsApp Community -->
        <a class="social-btn" href="https://chat.whatsapp.com/foais" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          foAIs Community
        </a>
*/}
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Courses -->
    <section id="courses" style="padding-bottom: 2rem;">
      <div class="section-header">
        <h2>Courses</h2>
      </div>

      <div class="courses-grid">
        {courses.map(course => (
          course.link
            ? <a class="course-card" href={course.link}>
                <div class="course-top">
                  <span class="course-title">{course.title}</span>
                  <span class="course-arrow">→</span>
                </div>
                <p class="course-description">{course.description}</p>
                <div class="course-meta">
                  {course.tags.map(tag => (
                    <span class="course-tag">{tag}</span>
                  ))}
                  <span class={`course-tag status-${course.status}`}>{course.statusLabel}</span>
                  {course.price && <span class="course-price">{course.price} · {course.seats}</span>}
                </div>
              </a>
            : <div class="course-card course-card--inactive">
                <div class="course-top">
                  <span class="course-title">{course.title}</span>
                </div>
                <div class="course-meta">
                  <span class={`course-tag status-${course.status}`}>{course.statusLabel}</span>
                </div>
              </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
