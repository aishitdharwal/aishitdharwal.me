---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Aishit Dharwal",
  description = "Head of AI at Skooc. Founder of AI Classroom. Teaching production AI engineering from first principles."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://aishitdharwal.me" />
    <meta property="og:site_name" content="Aishit Dharwal" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href="https://aishitdharwal.me" />
    <link rel="icon" type="image/x-icon" href="/icon.ico" />

    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="inner">
        <a href="/" class="nav-logo">aishit dharwal</a>
        <div class="nav-right">
          <ul class="nav-links">
            <li><a href="#courses">Courses</a></li>
            <li><a href="https://linkedin.com/in/aishit-dharwal" target="_blank">LinkedIn</a></li>
          </ul>
          <button id="theme-toggle" aria-label="Toggle dark mode">
            <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <script>
      function initTheme() {
        const toggle = document.getElementById('theme-toggle');
        const sun = document.getElementById('sun-icon');
        const moon = document.getElementById('moon-icon');
        const html = document.documentElement;

        const saved = localStorage.getItem('theme') || 'light';
        html.setAttribute('data-theme', saved);
        if (saved === 'dark') { sun.style.display = 'none'; moon.style.display = 'block'; }

        toggle.addEventListener('click', () => {
          const current = html.getAttribute('data-theme');
          const next = current === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          if (next === 'dark') { sun.style.display = 'none'; moon.style.display = 'block'; }
          else { sun.style.display = 'block'; moon.style.display = 'none'; }
        });
      }
      document.addEventListener('DOMContentLoaded', initTheme);
    </script>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span class="footer-left">© {new Date().getFullYear()} Aishit Dharwal</span>
        <ul class="footer-links">
          <li><a href="https://linkedin.com/in/aishit-dharwal" target="_blank">LinkedIn</a></li>
          <li><a href="https://instagram.com/aishit.builds" target="_blank">Instagram</a></li>
          <li><a href="mailto:aishit@aiclassroom.in">Contact</a></li>
        </ul>
      </div>
    </footer>
  </body>
</html>
